{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "ATAK AI Companion",
    "version": "0.2.0",
    "description": "Live AI Coach for League of Legends — ATAK.GG",
    "author": "ATAK GG",
    "icon": "icon.png",
    "icon_gray": "icon.png"
  },
  "permissions": ["GameEvents", "Launcher"],
  "game_targeting": {
    "type": "dedicated",
    "game_ids": [5426]
  },
  "windows": {
    "background": {
      "file": "background.html",
      "show_in_taskbar": false,
      "transparent": false,
      "resizable": false,
      "size": { "width": 0, "height": 0 },
      "start_position": { "top": 0, "left": 0 }
    },
    "in_game": {
      "file": "in_game.html",
      "transparent": true,
      "resizable": false,
      "show_in_taskbar": false,
      "keep_window_location": true,
      "use_os_windowing": false,
      "size": { "width": 420, "height": 520 },
      "start_position": { "top": 80, "left": 20 }
    }
  },
  "launch_events": [
    {
      "event": "GameLaunch",
      "event_data": { "game_ids": [5426] },
      "start_minimized": true
    }
  ]
}
