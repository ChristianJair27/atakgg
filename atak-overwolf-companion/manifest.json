{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "ATAK AI Companion",
    "version": "0.9.0",
    "description": "Live AI Coach for League of Legends — ATAK.GG",
    "author": "ATAK GG",
    "icon": "icon.png",
    "icon_gray": "icon.png",
    "minimum-overwolf-version": "0.200.0",
    "dock_button_title": "ATAK"
  },
  "permissions": [
    "GameInfo",
    "GameEvents",
    "Hotkeys",
    "FileSystem",
    "Tray",
    "Web"
  ],
  "data": {
    "start_window": "background",
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [5426]
    },
    "game_events": [5426],
    "windows": {
      "background": {
        "file": "background.html",
        "show_in_taskbar": false,
        "transparent": false,
        "resizable": false,
        "size": { "width": 400, "height": 300 },
        "start_position": { "top": 0, "left": 0 },
        "is_background_page": true
      },
      "in_game": {
        "file": "in_game.html",
        "transparent": false,
        "resizable": true,
        "show_in_taskbar": true,
        "keep_window_location": true,
        "use_os_windowing": true,
        "size": { "width": 400, "height": 560 },
        "start_position": { "top": 80, "left": 20 }
      },
      "champ_select": {
        "file": "champ_select.html",
        "transparent": false,
        "resizable": true,
        "show_in_taskbar": false,
        "keep_window_location": true,
        "use_os_windowing": false,
        "size": { "width": 1120, "height": 760 },
        "start_position": { "top": 60, "left": 800 }
      },
      "queue_profile": {
        "file": "queue_profile.html",
        "transparent": true,
        "resizable": false,
        "show_in_taskbar": false,
        "keep_window_location": true,
        "use_os_windowing": false,
        "size": { "width": 400, "height": 650 },
        "start_position": { "top": 80, "left": 1490 }
      },
      "arena_augments": {
        "file": "arena_augments.html",
        "transparent": true,
        "resizable": false,
        "show_in_taskbar": false,
        "keep_window_location": false,
        "use_os_windowing": false,
        "size": { "width": 540, "height": 134 },
        "start_position": { "top": 76, "left": 690 }
      },
      "end_of_game": {
        "file": "end_of_game.html",
        "transparent": true,
        "resizable": true,
        "show_in_taskbar": true,
        "keep_window_location": true,
        "use_os_windowing": false,
        "size": { "width": 1000, "height": 680 },
        "start_position": { "top": 80, "left": 160 }
      },
      "desktop": {
        "file": "desktop.html",
        "transparent": false,
        "resizable": true,
        "show_in_taskbar": true,
        "keep_window_location": true,
        "use_os_windowing": true,
        "size": { "width": 1440, "height": 900 },
        "start_position": { "top": 60, "left": 120 }
      },
      "home": {
        "file": "home.html",
        "transparent": false,
        "resizable": true,
        "show_in_taskbar": true,
        "keep_window_location": true,
        "use_os_windowing": true,
        "size": { "width": 1280, "height": 820 },
        "start_position": { "top": 60, "left": 120 }
      },
      "player_stats": {
        "file": "player_stats.html",
        "transparent": false,
        "resizable": true,
        "show_in_taskbar": true,
        "keep_window_location": true,
        "use_os_windowing": false,
        "size": { "width": 1300, "height": 720 },
        "start_position": { "top": 80, "left": 160 }
      }
    },
    "launch_events": [
      {
        "event": "GameLaunch",
        "event_data": {
          "game_ids": [5426]
        },
        "start_minimized": true
      }
    ],
    "hotkeys": {
      "toggle_app": {
        "title": "Toggle ATAK Overlay",
        "action-type": "toggle",
        "default": "F9"
      },
      "toggle_scoreboard": {
        "title": "Toggle Player Stats",
        "action-type": "toggle",
        "default": "Ctrl+Shift+S"
      }
    }
  }
}
